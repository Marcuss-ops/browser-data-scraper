# Artlist MP4 Scraper - Environment Variables
# Copy this file to .env and update with your values

# Output directory for downloaded videos
SCRAPER_OUTPUT_DIR=./Output

# API Keys (optional - defaults to hardcoded values)
PIXABAY_API_KEY=your_pixabay_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Artlist GraphQL API (no auth required - uses public endpoint)
# ARTLIST_GRAPHQL_URL=https://search-api.artlist.io/v1/graphql

# Lightpanda Browser (optional - for browser-based scraping)
LIGHTPANDA_WS_URL=ws://127.0.0.1:9222

# Database path (optional - defaults to artlist_videos.db in project root)
# DATABASE_PATH=./artlist_videos.db
